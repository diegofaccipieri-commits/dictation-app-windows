{
  "$schema": "https://raw.githubusercontent.com/nicorichard/tauri-v2-schema/refs/heads/main/schema.json",
  "productName": "DictationApp",
  "identifier": "com.diego.dictationapp.windows",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DictationApp",
        "width": 360,
        "height": 400,
        "resizable": false,
        "visible": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "resources": [
      "vulkan-bin"
    ],
    "createUpdaterArtifacts": "v2"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/diegofaccipieri-commits/dictation-app-windows/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFMThCQTZFNjQwOUVDNDIKUldSQzdBbGticm9ZdmdJMTVPcm5HT1JEUXowWTM0TVF2aVgwVDVUR3dwK2Zqa1ZkQkNWenJManQK"
    }
  }
}
