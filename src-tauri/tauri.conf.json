{
  "$schema": "https://raw.githubusercontent.com/nicorichard/tauri-v2-schema/refs/heads/main/schema.json",
  "productName": "DictationApp",
  "identifier": "com.diego.dictationapp.windows",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DictationApp",
        "width": 360,
        "height": 400,
        "resizable": false,
        "visible": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": false
  }
}
